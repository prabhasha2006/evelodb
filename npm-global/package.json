{
  "name": "evelodb-global",
  "version": "1.0.2",
  "description": "EveloDB - Global client library for Node.js",
  "main": "./dist/evelodb-global.js",
  "types": "./dist/evelodb-global.d.ts",
  "exports": {
    ".": {
      "require": "./dist/evelodb-global.js",
      "import": "./dist/evelodb-global.js",
      "types": "./dist/evelodb-global.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prebuild": "npm run clean",
    "clean": "rimraf dist",
    "watch": "tsc --watch",
    "prepublish": "npm run build"
  },
  "keywords": [
    "evelodb",
    "evelodb-server",
    "evelodb-global",
    "database",
    "json",
    "bson",
    "evelocore",
    "dbms",
    "b-tree"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "typescript": ">=4.0.0"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/prabhasha2006/evelodb-global.git"
  }
}
